#!/data/data/com.termux/files/usr/bin/bash
# ai-dev — AI/ML development environment for Termux
set -euo pipefail
source "$(dirname "$0")/../lib/common.sh"

usage() {
    cat <<EOF
Usage: ai-dev <command>

Set up AI/ML development tools on Termux.

Commands:
  python-ml        Install Python ML stack (numpy, pandas, scikit-learn, etc.)
  jupyter          Set up Jupyter notebook server (accessible from phone browser)
  huggingface      Install Hugging Face CLI + transformers
  langchain        Install LangChain + dependencies
  api-server       Create a FastAPI server template for your local models
  new-project      Scaffold a new AI project directory
  --help, -h       Show this help

Examples:
  ai-dev python-ml
  ai-dev jupyter
  ai-dev new-project my-chatbot
EOF
}

setup_python_ml() {
    step "Setting up Python ML environment..."

    has python || pkg_install python python-pip
    pkg_install python-numpy libopenblas 2>/dev/null || true

    info "Installing core ML packages..."
    pip install --upgrade pip
    pip install \
        numpy \
        pandas \
        scikit-learn \
        matplotlib \
        requests \
        httpx \
        pydantic \
        tqdm \
        rich \
        2>/dev/null || true

    info "Installing AI-specific packages..."
    pip install \
        openai \
        tiktoken \
        chromadb \
        sentence-transformers \
        2>/dev/null || true

    ok "Python ML environment ready."
    info "Test with: python -c 'import numpy; print(numpy.__version__)'"
}

setup_jupyter() {
    step "Setting up Jupyter notebook..."

    has python || pkg_install python python-pip
    pkg_install libzmq 2>/dev/null || true

    pip install jupyter notebook ipykernel 2>/dev/null || true

    # Create a startup script
    mkdir -p "$HOME/bin"
    cat > "$HOME/bin/jupyter-start" <<'SCRIPT'
#!/data/data/com.termux/files/usr/bin/bash
# Start Jupyter notebook server
PORT="${1:-8888}"
echo "Starting Jupyter on port $PORT..."
echo "Open in your browser: http://localhost:$PORT"
echo ""
jupyter notebook \
    --ip=0.0.0.0 \
    --port="$PORT" \
    --no-browser \
    --NotebookApp.token='' \
    --NotebookApp.password='' \
    --notebook-dir="$HOME/notebooks"
SCRIPT
    chmod +x "$HOME/bin/jupyter-start"

    mkdir -p "$HOME/notebooks"

    ok "Jupyter installed."
    info "Start with: jupyter-start"
    info "Then open http://localhost:8888 in your phone's browser."
}

setup_huggingface() {
    step "Setting up Hugging Face tools..."

    has python || pkg_install python python-pip

    pip install \
        huggingface-hub \
        transformers \
        datasets \
        accelerate \
        2>/dev/null || true

    # Install the CLI
    pip install huggingface-hub[cli] 2>/dev/null || true

    ok "Hugging Face tools installed."
    info "Login with: huggingface-cli login"
    info "Browse models: huggingface-cli repo list"
}

setup_langchain() {
    step "Setting up LangChain..."

    has python || pkg_install python python-pip

    pip install \
        langchain \
        langchain-community \
        langchain-core \
        langserve \
        2>/dev/null || true

    # Ollama integration
    pip install langchain-ollama 2>/dev/null || true

    ok "LangChain installed with Ollama integration."
    info "Quick test:"
    echo "  from langchain_ollama import OllamaLLM"
    echo "  llm = OllamaLLM(model='qwen2.5:7b')"
    echo "  print(llm.invoke('Hello!'))"
}

create_api_server() {
    step "Creating FastAPI model server template..."

    has python || pkg_install python python-pip
    pip install fastapi uvicorn openai 2>/dev/null || true

    local project_dir="$HOME/ai-api-server"
    mkdir -p "$project_dir"

    cat > "$project_dir/server.py" <<'PYEOF'
"""
FastAPI server that wraps your local Ollama models with a clean REST API.
Run with: uvicorn server:app --host 0.0.0.0 --port 8000
"""
import os
from fastapi import FastAPI, HTTPException
from pydantic import BaseModel
from openai import OpenAI

app = FastAPI(title="Termux AI API", version="1.0")

client = OpenAI(
    base_url=os.environ.get("OLLAMA_URL", "http://127.0.0.1:11434/v1"),
    api_key="ollama",
)
DEFAULT_MODEL = os.environ.get("AI_MODEL", "qwen2.5:7b")


class ChatRequest(BaseModel):
    message: str
    model: str = DEFAULT_MODEL
    system: str = "You are a helpful assistant."


class ChatResponse(BaseModel):
    reply: str
    model: str


@app.get("/")
def health():
    return {"status": "ok", "default_model": DEFAULT_MODEL}


@app.post("/chat", response_model=ChatResponse)
def chat(req: ChatRequest):
    try:
        resp = client.chat.completions.create(
            model=req.model,
            messages=[
                {"role": "system", "content": req.system},
                {"role": "user", "content": req.message},
            ],
        )
        return ChatResponse(
            reply=resp.choices[0].message.content,
            model=req.model,
        )
    except Exception as e:
        raise HTTPException(status_code=500, detail=str(e))


@app.post("/generate")
def generate(req: ChatRequest):
    """Streaming endpoint."""
    from fastapi.responses import StreamingResponse

    def stream():
        resp = client.chat.completions.create(
            model=req.model,
            messages=[{"role": "user", "content": req.message}],
            stream=True,
        )
        for chunk in resp:
            content = chunk.choices[0].delta.content
            if content:
                yield content

    return StreamingResponse(stream(), media_type="text/plain")
PYEOF

    cat > "$project_dir/start.sh" <<'SHEOF'
#!/data/data/com.termux/files/usr/bin/bash
echo "Starting AI API server on port 8000..."
echo "Docs: http://localhost:8000/docs"
cd "$(dirname "$0")"
uvicorn server:app --host 0.0.0.0 --port 8000 --reload
SHEOF
    chmod +x "$project_dir/start.sh"

    ok "API server template created at $project_dir/"
    info "Start with: cd $project_dir && ./start.sh"
    info "Interactive docs at: http://localhost:8000/docs"
}

scaffold_project() {
    local name="${1:?Usage: ai-dev new-project <name>}"
    local dir="$HOME/projects/$name"

    if [ -d "$dir" ]; then
        err "Directory already exists: $dir"
        exit 1
    fi

    step "Scaffolding AI project: $name"
    mkdir -p "$dir"/{src,data,notebooks,models,tests}

    # Main script
    cat > "$dir/src/main.py" <<PYEOF
"""$name — AI project scaffold."""
import os
from openai import OpenAI

# Works with local Ollama or any OpenAI-compatible API
client = OpenAI(
    base_url=os.environ.get("OPENAI_BASE_URL", "http://127.0.0.1:11434/v1"),
    api_key=os.environ.get("OPENAI_API_KEY", "ollama"),
)
MODEL = os.environ.get("AI_MODEL", "qwen2.5:7b")


def chat(prompt: str, system: str = "You are a helpful assistant.") -> str:
    response = client.chat.completions.create(
        model=MODEL,
        messages=[
            {"role": "system", "content": system},
            {"role": "user", "content": prompt},
        ],
    )
    return response.choices[0].message.content


if __name__ == "__main__":
    reply = chat("Hello! What can you help me with?")
    print(reply)
PYEOF

    # Requirements
    cat > "$dir/requirements.txt" <<'REQ'
openai>=1.0
requests
httpx
pydantic
python-dotenv
rich
tqdm
REQ

    # .env template
    cat > "$dir/.env.example" <<'ENV'
# Copy to .env and fill in your values
OPENAI_BASE_URL=http://127.0.0.1:11434/v1
OPENAI_API_KEY=ollama
AI_MODEL=qwen2.5:7b
# GEMINI_API_KEY=your-key-here
# DASHSCOPE_API_KEY=your-key-here
ENV

    # .gitignore
    cat > "$dir/.gitignore" <<'GIT'
.env
__pycache__/
*.pyc
.venv/
data/
models/
*.bin
*.gguf
GIT

    # README
    cat > "$dir/README.md" <<MDEOF
# $name

AI project running on Termux (Pixel 8 Pro).

## Setup

\`\`\`bash
cd $dir
python -m venv .venv
source .venv/bin/activate
pip install -r requirements.txt
cp .env.example .env
\`\`\`

## Run

\`\`\`bash
# Make sure Ollama is running
setup-ollama start

# Run the project
python src/main.py
\`\`\`
MDEOF

    ok "Project scaffolded at $dir/"
    info "Next steps:"
    info "  cd $dir"
    info "  python -m venv .venv && source .venv/bin/activate"
    info "  pip install -r requirements.txt"
}

case "${1:-}" in
    python-ml)      setup_python_ml ;;
    jupyter)        setup_jupyter ;;
    huggingface|hf) setup_huggingface ;;
    langchain)      setup_langchain ;;
    api-server)     create_api_server ;;
    new-project)    scaffold_project "${2:-}" ;;
    --help|-h)      usage ;;
    "")             usage ;;
    *)              err "Unknown command: $1"; usage; exit 1 ;;
esac
