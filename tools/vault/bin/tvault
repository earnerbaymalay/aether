#!/data/data/com.termux/files/usr/bin/bash
# tvault — main entry point for Termux-Vault tools
set -euo pipefail

VAULT_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
VAULT_BIN="$VAULT_ROOT/bin"

VERSION="1.0.0"

usage() {
    cat <<EOF
tvault $VERSION — Termux helper tools

Usage: tvault <tool> [args...]

AI Tools (Pixel 8 Pro optimized):
  setup-ollama       Install/manage Ollama + models (Qwen, Gemma, Llama)
  setup-ai           Set up Gemini CLI, Qwen, API keys, shell integration
  ai-dev             AI dev environment (Python ML, Jupyter, LangChain, HF)

General Tools:
  setup-dev          Set up development environments (Python, Node, Rust, etc.)
  pkg-bundle         Install curated package bundles
  storage-fix        Fix storage permissions and create symlinks
  keygen             Generate and manage SSH/GPG keys
  dotfiles           Shell configuration manager (zsh, bash, vim, tmux)
  netkit             Network utilities (serve, scan, api, dns, etc.)
  tbackup            Backup and restore Termux environment
  proot-distro-setup Install full Linux distros via proot

Meta:
  help, --help       Show this help
  version            Show version
  list               List all available tools
  doctor             Check system health

Run 'tvault <tool> --help' for tool-specific help.

Examples:
  tvault setup-ollama install          # install Ollama
  tvault setup-ollama pull qwen2.5:7b  # download Qwen 7B
  tvault setup-ai shell-integration    # add ask/code/explain to shell
  tvault ai-dev jupyter                # set up Jupyter notebooks
  tvault setup-dev python node
  tvault pkg-bundle dev-core ai-dev
EOF
}

doctor() {
    echo "tvault doctor — system health check"
    echo "===================================="

    local ok_count=0
    local warn_count=0

    check() {
        if command -v "$1" >/dev/null 2>&1; then
            printf "  \033[1;32m[ok]\033[0m  %-20s %s\n" "$1" "$($1 --version 2>&1 | head -1)"
            ((ok_count++))
        else
            printf "  \033[1;33m[--]\033[0m  %-20s not installed\n" "$1"
            ((warn_count++))
        fi
    }

    echo ""
    echo "Core tools:"
    check bash
    check git
    check curl
    check wget
    check ssh
    check python
    check node
    check pkg

    echo ""
    echo "AI tools:"
    check ollama
    check gemini
    check jupyter
    if curl -s "http://127.0.0.1:11434/api/version" >/dev/null 2>&1; then
        printf "  \033[1;32m[ok]\033[0m  %-20s running\n" "ollama-server"
        ((ok_count++))
    else
        printf "  \033[1;33m[--]\033[0m  %-20s not running\n" "ollama-server"
        ((warn_count++))
    fi

    echo ""
    echo "Environment:"
    printf "  PREFIX:     %s\n" "${PREFIX:-unset}"
    printf "  HOME:       %s\n" "$HOME"
    printf "  SHELL:      %s\n" "${SHELL:-unset}"
    printf "  Storage:    %s\n" "$([ -d "$HOME/storage" ] && echo "mounted" || echo "not set up")"

    echo ""
    echo "Termux-Vault:"
    printf "  Version:    %s\n" "$VERSION"
    printf "  Location:   %s\n" "$VAULT_ROOT"
    printf "  Tools:      %s\n" "$(ls "$VAULT_BIN" | wc -l) scripts"

    echo ""
    printf "Results: %d ok, %d missing\n" "$ok_count" "$warn_count"
}

list_tools() {
    echo "Available tools:"
    for tool in "$VAULT_BIN"/*; do
        [ -x "$tool" ] && [ "$(basename "$tool")" != "tvault" ] && echo "  $(basename "$tool")"
    done
}

case "${1:-}" in
    --help|-h|help|"")
        usage ;;
    --version|version)
        echo "tvault $VERSION" ;;
    doctor)
        doctor ;;
    list)
        list_tools ;;
    *)
        tool="$VAULT_BIN/$1"
        if [ -x "$tool" ]; then
            shift
            exec "$tool" "$@"
        else
            echo "Error: unknown tool '$1'" >&2
            echo "Run 'tvault list' to see available tools." >&2
            exit 1
        fi
        ;;
esac
