#!/data/data/com.termux/files/usr/bin/bash
# dotfiles — shell configuration manager for Termux
set -euo pipefail
source "$(dirname "$0")/../lib/common.sh"

DOTFILES_DIR="$VAULT_CONFIG/dotfiles"

usage() {
    cat <<EOF
Usage: dotfiles <command>

Manage shell configuration and dotfiles.

Commands:
  setup-zsh       Install zsh + oh-my-zsh + plugins + Termux-friendly theme
  setup-bash      Apply an enhanced .bashrc with aliases and prompt
  aliases         Install a comprehensive alias file (~/.aliases)
  tmux            Install a Termux-optimized tmux config
  vimrc           Install a sensible .vimrc
  profile         Show what's currently configured
  --help, -h      Show this help

Examples:
  dotfiles setup-zsh
  dotfiles aliases
  dotfiles tmux
EOF
}

backup_file() {
    local f="$1"
    if [ -f "$f" ]; then
        cp "$f" "${f}.bak.$(date +%s)"
        info "Backed up $f"
    fi
}

setup_zsh() {
    step "Setting up zsh..."
    has zsh || pkg_install zsh

    # oh-my-zsh
    if [ ! -d "$HOME/.oh-my-zsh" ]; then
        info "Installing oh-my-zsh..."
        sh -c "$(curl -fsSL https://raw.githubusercontent.com/ohmyzsh/ohmyzsh/master/tools/install.sh)" "" --unattended
    else
        info "oh-my-zsh already installed."
    fi

    # plugins
    local zsh_custom="${ZSH_CUSTOM:-$HOME/.oh-my-zsh/custom}"

    if [ ! -d "$zsh_custom/plugins/zsh-autosuggestions" ]; then
        git clone https://github.com/zsh-users/zsh-autosuggestions "$zsh_custom/plugins/zsh-autosuggestions"
    fi
    if [ ! -d "$zsh_custom/plugins/zsh-syntax-highlighting" ]; then
        git clone https://github.com/zsh-users/zsh-syntax-highlighting "$zsh_custom/plugins/zsh-syntax-highlighting"
    fi

    # .zshrc
    backup_file "$HOME/.zshrc"
    cat > "$HOME/.zshrc" <<'ZSHRC'
export ZSH="$HOME/.oh-my-zsh"
ZSH_THEME="agnoster"
plugins=(git zsh-autosuggestions zsh-syntax-highlighting command-not-found)
source $ZSH/oh-my-zsh.sh

# Aliases
[ -f ~/.aliases ] && source ~/.aliases

# Termux-specific
export EDITOR=nano
export LANG=en_US.UTF-8
ZSHRC

    # Set zsh as default
    chsh -s zsh 2>/dev/null || true
    ok "zsh configured. Restart Termux or run 'zsh' to switch."
}

setup_bash() {
    step "Setting up enhanced bash..."
    backup_file "$HOME/.bashrc"

    cat > "$HOME/.bashrc" <<'BASHRC'
# Termux-Vault enhanced .bashrc

# Prompt
PS1='\[\033[1;32m\]\u@termux\[\033[0m\]:\[\033[1;34m\]\w\[\033[0m\]\$ '

# History
HISTSIZE=10000
HISTFILESIZE=20000
HISTCONTROL=ignoreboth:erasedups
shopt -s histappend

# Better defaults
shopt -s checkwinsize
shopt -s globstar 2>/dev/null
shopt -s cdspell

# Aliases
[ -f ~/.aliases ] && source ~/.aliases

# Environment
export EDITOR=nano
export LANG=en_US.UTF-8
export TERM=xterm-256color

# Tab completion
bind 'set show-all-if-ambiguous on'
bind 'set completion-ignore-case on'
BASHRC

    ok "Bash configured. Run 'source ~/.bashrc' to apply."
}

install_aliases() {
    step "Installing aliases..."
    backup_file "$HOME/.aliases"

    cat > "$HOME/.aliases" <<'ALIASES'
# --- Navigation ---
alias ..='cd ..'
alias ...='cd ../..'
alias ....='cd ../../..'
alias ~='cd ~'

# --- Listing ---
alias ll='ls -lAh --color=auto'
alias la='ls -A --color=auto'
alias l='ls -CF --color=auto'
alias lt='ls -lAht --color=auto'   # sort by time

# --- Safety ---
alias rm='rm -i'
alias cp='cp -i'
alias mv='mv -i'

# --- Git ---
alias g='git'
alias gs='git status'
alias ga='git add'
alias gc='git commit'
alias gp='git push'
alias gl='git log --oneline -20'
alias gd='git diff'
alias gb='git branch'
alias gco='git checkout'

# --- Python ---
alias py='python'
alias pip='pip3'
alias venv='python -m venv'
alias activate='source ./venv/bin/activate'

# --- Misc ---
alias cls='clear'
alias h='history'
alias path='echo $PATH | tr ":" "\n"'
alias myip='curl -s ifconfig.me'
alias weather='curl -s wttr.in/?format=3'
alias ports='netstat -tuln'
alias sizeof='du -sh'

# --- Termux ---
alias battery='termux-battery-status 2>/dev/null | jq .'
alias clip='termux-clipboard-get'
alias setclip='termux-clipboard-set'
alias vibrate='termux-vibrate'
alias torch='termux-torch on'
alias torchoff='termux-torch off'
alias share='termux-share'
ALIASES

    ok "Aliases installed at ~/.aliases"
    info "They'll be loaded automatically if you use dotfiles setup-bash or setup-zsh."
}

install_tmux() {
    step "Setting up tmux..."
    has tmux || pkg_install tmux
    backup_file "$HOME/.tmux.conf"

    cat > "$HOME/.tmux.conf" <<'TMUX'
# Termux-optimized tmux config

# Better prefix
set -g prefix C-a
unbind C-b
bind C-a send-prefix

# Mouse support
set -g mouse on

# 256 colors
set -g default-terminal "screen-256color"

# Start windows at 1
set -g base-index 1
setw -g pane-base-index 1

# Easy splits
bind | split-window -h -c "#{pane_current_path}"
bind - split-window -v -c "#{pane_current_path}"

# Vim-style pane navigation
bind h select-pane -L
bind j select-pane -D
bind k select-pane -U
bind l select-pane -R

# Resize panes
bind -r H resize-pane -L 5
bind -r J resize-pane -D 5
bind -r K resize-pane -U 5
bind -r L resize-pane -R 5

# Status bar
set -g status-style 'bg=colour235 fg=colour136'
set -g status-left '#[fg=colour46]#S '
set -g status-right '#[fg=colour136]%H:%M'

# Quick reload
bind r source-file ~/.tmux.conf \; display "Reloaded!"

# Increase scrollback
set -g history-limit 50000
TMUX

    ok "tmux configured. Run 'tmux' to start."
}

install_vimrc() {
    step "Setting up vim..."
    has vim || pkg_install vim
    backup_file "$HOME/.vimrc"

    cat > "$HOME/.vimrc" <<'VIMRC'
" Termux-friendly .vimrc
set nocompatible
filetype plugin indent on
syntax on

set number
set relativenumber
set cursorline
set showmatch
set hlsearch
set incsearch
set ignorecase
set smartcase

set tabstop=4
set shiftwidth=4
set expandtab
set autoindent
set smartindent

set scrolloff=8
set sidescrolloff=8
set wrap
set linebreak

set wildmenu
set wildmode=longest:full,full

set mouse=a
set clipboard=unnamedplus
set encoding=utf-8
set backspace=indent,eol,start

" Disable swap files (avoids issues on Termux storage)
set noswapfile
set nobackup
set nowritebackup

" Status line
set laststatus=2
set statusline=%f\ %m%r%h%w\ %=%l/%L\ col:%c\ %p%%

" Key maps
let mapleader=" "
nnoremap <leader>w :w<CR>
nnoremap <leader>q :q<CR>
nnoremap <leader>n :noh<CR>
VIMRC

    ok "vim configured."
}

show_profile() {
    step "Current shell configuration:"
    info "Shell:    $SHELL"
    info "TERM:     ${TERM:-unset}"
    info "EDITOR:   ${EDITOR:-unset}"

    echo ""
    for f in .bashrc .zshrc .aliases .tmux.conf .vimrc; do
        if [ -f "$HOME/$f" ]; then
            ok "  ~/$f exists ($(wc -l < "$HOME/$f") lines)"
        else
            info "  ~/$f not found"
        fi
    done
}

case "${1:-}" in
    setup-zsh)   setup_zsh ;;
    setup-bash)  setup_bash ;;
    aliases)     install_aliases ;;
    tmux)        install_tmux ;;
    vimrc)       install_vimrc ;;
    profile)     show_profile ;;
    --help|-h)   usage ;;
    "")          usage ;;
    *)           err "Unknown command: $1"; usage; exit 1 ;;
esac
