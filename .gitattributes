# Auto-detect text files and normalize line endings
* text=auto

# Explicitly declare text files that should use LF
*.sh text eol=lf
*.bash text eol=lf
*.py text eol=lf
*.kt text eol=lf
*.kts text eol=lf
*.java text eol=lf
*.xml text eol=lf
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.toml text eol=lf
*.properties text eol=lf
*.pro text eol=lf
*.conf text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.svg binary
*.ico binary
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary
*.jar binary
*.aar binary
*.so binary
*.dylib binary
*.dll binary
*.exe binary
