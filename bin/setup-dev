#!/data/data/com.termux/files/usr/bin/bash
# setup-dev — one-command dev environment setup for Termux
set -euo pipefail
source "$(dirname "$0")/../lib/common.sh"

usage() {
    cat <<EOF
Usage: setup-dev <language> [language...]

Set up a full development environment for one or more languages.

Supported languages:
  python    Python 3 + pip + venv + common libs
  node      Node.js LTS + npm + yarn + common global tools
  rust      Rust via rustup + cargo
  go        Go toolchain
  c         Clang + make + cmake + gdb + pkg-config
  ruby      Ruby + gem + bundler
  java      OpenJDK + gradle

Options:
  all        Install everything
  --help     Show this help

Examples:
  setup-dev python node
  setup-dev rust
  setup-dev all
EOF
}

setup_python() {
    step "Setting up Python..."
    pkg_install python python-pip
    pip install --upgrade pip 2>/dev/null || true
    pip install virtualenv ipython requests flask 2>/dev/null || true
    ok "Python ready. Run 'python' or 'ipython'."
}

setup_node() {
    step "Setting up Node.js..."
    pkg_install nodejs-lts yarn
    npm install -g npm@latest 2>/dev/null || true
    npm install -g typescript ts-node eslint prettier 2>/dev/null || true
    ok "Node.js ready. Run 'node' or 'npx'."
}

setup_rust() {
    step "Setting up Rust..."
    if has rustc; then
        info "Rust already installed ($(rustc --version)). Updating..."
        rustup update 2>/dev/null || true
    else
        pkg_install rust
    fi
    ok "Rust ready. Run 'rustc' or 'cargo'."
}

setup_go() {
    step "Setting up Go..."
    pkg_install golang
    # set up GOPATH
    mkdir -p "$HOME/go/bin"
    if ! grep -q 'GOPATH' "$HOME/.bashrc" 2>/dev/null; then
        {
            echo ''
            echo '# Go environment'
            echo 'export GOPATH=$HOME/go'
            echo 'export PATH=$GOPATH/bin:$PATH'
        } >> "$HOME/.bashrc"
    fi
    ok "Go ready. Run 'go version'. Restart shell or source ~/.bashrc for PATH."
}

setup_c() {
    step "Setting up C/C++..."
    pkg_install clang make cmake gdb pkg-config binutils
    ok "C/C++ ready. Compile with 'clang' or 'clang++'."
}

setup_ruby() {
    step "Setting up Ruby..."
    pkg_install ruby
    gem install bundler 2>/dev/null || true
    ok "Ruby ready. Run 'ruby' or 'irb'."
}

setup_java() {
    step "Setting up Java..."
    pkg_install openjdk-17
    ok "Java ready. Run 'java -version'."
}

if [ $# -eq 0 ] || [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
    usage
    exit 0
fi

step "Updating package index..."
pkg update -y -q 2>/dev/null || true

targets=("$@")
if [[ " ${targets[*]} " =~ " all " ]]; then
    targets=(python node rust go c ruby java)
fi

for lang in "${targets[@]}"; do
    case "$lang" in
        python) setup_python ;;
        node)   setup_node ;;
        rust)   setup_rust ;;
        go)     setup_go ;;
        c)      setup_c ;;
        ruby)   setup_ruby ;;
        java)   setup_java ;;
        all)    ;; # handled above
        *)      err "Unknown language: $lang" ;;
    esac
done

ok "Dev environment setup complete!"
