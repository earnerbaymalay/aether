#!/usr/bin/env python3
import argparse, sys, requests, os, subprocess

# Set absolute paths
BASE = os.path.expanduser("~/termux-ai-workspace/tools/nexus")
sys.path.append(os.path.join(BASE, "core"))

# TUI Colors
C, G, R, Y, B, NC = '\033[1;36m', '\033[1;32m', '\033[1;31m', '\033[1;33m', '\033[1m', '\033[0m'
BRAIN = os.path.join(BASE, "core/brain.md")
BLOCKLIST = os.path.join(BASE, "logs/nexus_blocklist.txt")

# Try to import security logic
try:
    import siem
except ImportError:
    siem = None

def call_ai(prompt, context="You are the Nexus AI.", model="dolphin-phi:latest"):
    token = os.environ.get("NEXUS_API_TOKEN", "nexus-dev-2026")
    try:
        res = requests.post("http://127.0.0.1:5000/ai/process", 
                            json={"input": prompt, "system": context, "model": model},
                            headers={"Authorization": f"Bearer {token}"}, timeout=300)
        return res.json().get("output", "Error")
    except:
        return f"{R}Hub Offline. Run 'nexus start'{NC}"

def main():
    parser = argparse.ArgumentParser(description="Nexus AI Workspace")
    sub = parser.add_subparsers(dest="cmd")
    
    # Simple Commands
    for c in ["start", "health", "recall", "sync", "report", "version", "update"]:
        sub.add_parser(c)
    
    # Commands with Arguments
    p_ask = sub.add_parser("ask"); p_ask.add_argument("q"); p_ask.add_argument("-m", "--model", default="dolphin-phi:latest")
    p_chat = sub.add_parser("chat"); p_chat.add_argument("-m", "--model", default="dolphin-phi:latest")
    p_rem = sub.add_parser("remember"); p_rem.add_argument("f")
    p_sum = sub.add_parser("summarize"); p_sum.add_argument("file")
    p_rec = sub.add_parser("recon"); p_rec.add_argument("-t", "--target", required=True)
    p_sen = sub.add_parser("sentinel"); p_sen.add_argument("-f", "--file", required=True)
    p_blk = sub.add_parser("block"); p_blk.add_argument("ip")

    args = parser.parse_args()

    if args.cmd == "start":
        subprocess.run("lsof -t -i:5000 | xargs kill -9", shell=True, stderr=subprocess.DEVNULL)
        subprocess.Popen(["python3", os.path.join(BASE, "core/hub.py")], stdout=subprocess.DEVNULL)
        print(f"{G}🚀 Nexus Hub Starting...{NC}")

    elif args.cmd == "health":
        try:
            requests.get("http://127.0.0.1:5000/health", timeout=2)
            print(f"{G}✓ Nexus Systems Nominal.{NC}")
        except:
            print(f"{R}✗ Nexus Systems Offline.{NC}")

    elif args.cmd == "recon":
        if siem:
            raw = siem.run_nmap(args.target)
            print(f"{Y}🛡️ AI Analyzing Network Scan...{NC}")
            print(call_ai(raw, "Analyze this Nmap output for security risks."))
        else: print(f"{R}Security Module Missing.{NC}")

    elif args.cmd == "sentinel":
        if siem:
            logs = siem.analyze_logs(args.file)
            print(f"{Y}🔍 AI Performing Forensic Log Analysis...{NC}")
            print(call_ai(logs, "Identify unauthorized access or brute-force patterns."))
        else: print(f"{R}Security Module Missing.{NC}")

    elif args.cmd == "block":
        os.makedirs(os.path.dirname(BLOCKLIST), exist_ok=True)
        with open(BLOCKLIST, "a") as f: f.write(f"{args.ip}\n")
        print(f"{R}🚫 IP {args.ip} blacklisted in Nexus database.{NC}")

    elif args.cmd == "remember":
        with open(BRAIN, "a") as f: f.write(f"- {args.f}\n")
        print(f"{G}✓ Etched into memory.{NC}")

    elif args.cmd == "recall":
        if os.path.exists(BRAIN):
            print(f"{C}{B}🧠 AI Persistent Memory:{NC}\n{open(BRAIN).read()}")
        else: print(f"{Y}Memory is currently empty.{NC}")

    elif args.cmd == "sync":
        REPO_ROOT = os.path.expanduser("~/termux-ai-workspace")
        subprocess.run(["git", "add", "."], cwd=REPO_ROOT)
        subprocess.run(["git", "commit", "-m", "Portfolio Sync - Nexus v2.5"], cwd=REPO_ROOT)
        print(f"{G}✓ Workspace versioned and ready to push.{NC}")

    elif args.cmd == "ask":
        print(f"{G}Nexus ({args.model}):{NC} {call_ai(args.q, model=args.model)}")

    elif args.cmd == "chat":
        print(f"{Y}Nexus Chat [{args.model}] (exit to quit){NC}")
        while True:
            u = input(f"{C}User > {NC}")
            if u.lower() in ['exit', 'quit']: break
            print(f"{G}Nexus > {NC}{call_ai(u, model=args.model)}")

    elif args.cmd == "report":
        mem = open(BRAIN).read() if os.path.exists(BRAIN) else "No data."
        print(call_ai(mem, "Write a professional Cybersecurity Progress Report based on these facts."))

    else: parser.print_help()

if __name__ == "__main__":
    main()
