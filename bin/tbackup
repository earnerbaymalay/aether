#!/data/data/com.termux/files/usr/bin/bash
# tbackup — backup and restore Termux environment
set -euo pipefail
source "$(dirname "$0")/../lib/common.sh"

BACKUP_DIR="$VAULT_ROOT/backups"
mkdir -p "$BACKUP_DIR"

usage() {
    cat <<EOF
Usage: tbackup <command> [options]

Backup and restore your Termux environment.

Commands:
  save [name]      Create a backup of the current environment
  restore <file>   Restore from a backup archive
  list             List available backups
  pkg-list         Export list of installed packages
  pkg-restore      Reinstall packages from exported list

What gets backed up:
  - Installed package list
  - ~/.bashrc, ~/.zshrc, ~/.aliases, ~/.vimrc, ~/.tmux.conf
  - ~/.ssh/ (keys and config)
  - ~/.gitconfig
  - ~/bin/ (user scripts)
  - Termux properties (~/.termux/)

Options:
  --help, -h       Show this help

Examples:
  tbackup save my-setup
  tbackup list
  tbackup restore backups/my-setup-20240101.tar.gz
  tbackup pkg-list > my-packages.txt
EOF
}

backup_save() {
    local name="${1:-termux-backup}"
    local timestamp
    timestamp=$(date +%Y%m%d-%H%M%S)
    local archive="$BACKUP_DIR/${name}-${timestamp}.tar.gz"
    local tmpdir
    tmpdir=$(mktemp -d)
    local manifest="$tmpdir/manifest"

    step "Creating backup: $name"

    # Package list
    info "Saving package list..."
    dpkg --get-selections 2>/dev/null | awk '{print $1}' > "$tmpdir/packages.txt"

    # Dotfiles
    info "Saving dotfiles..."
    mkdir -p "$tmpdir/dotfiles"
    for f in .bashrc .zshrc .aliases .vimrc .tmux.conf .gitconfig .profile; do
        [ -f "$HOME/$f" ] && cp "$HOME/$f" "$tmpdir/dotfiles/"
    done

    # SSH
    if [ -d "$HOME/.ssh" ]; then
        info "Saving SSH config..."
        cp -r "$HOME/.ssh" "$tmpdir/ssh"
    fi

    # Termux config
    if [ -d "$HOME/.termux" ]; then
        info "Saving Termux config..."
        cp -r "$HOME/.termux" "$tmpdir/termux-config"
    fi

    # User bin
    if [ -d "$HOME/bin" ]; then
        info "Saving ~/bin..."
        cp -r "$HOME/bin" "$tmpdir/user-bin"
    fi

    # Manifest
    {
        echo "Termux-Vault backup"
        echo "Date: $(date)"
        echo "Name: $name"
        echo "Packages: $(wc -l < "$tmpdir/packages.txt")"
    } > "$manifest"

    # Archive
    step "Compressing..."
    tar -czf "$archive" -C "$tmpdir" .
    rm -rf "$tmpdir"

    local size
    size=$(du -h "$archive" | cut -f1)
    ok "Backup saved: $archive ($size)"
}

backup_restore() {
    local archive="${1:?Usage: tbackup restore <file>}"

    if [ ! -f "$archive" ]; then
        err "File not found: $archive"
        exit 1
    fi

    step "Restoring from: $archive"
    local tmpdir
    tmpdir=$(mktemp -d)
    tar -xzf "$archive" -C "$tmpdir"

    # Show manifest
    if [ -f "$tmpdir/manifest" ]; then
        info "Backup info:"
        cat "$tmpdir/manifest"
        echo ""
    fi

    if ! confirm "Proceed with restore? Existing files will be overwritten."; then
        rm -rf "$tmpdir"
        info "Cancelled."
        exit 0
    fi

    # Restore dotfiles
    if [ -d "$tmpdir/dotfiles" ]; then
        info "Restoring dotfiles..."
        cp -f "$tmpdir/dotfiles/"* "$HOME/" 2>/dev/null || true
    fi

    # Restore SSH
    if [ -d "$tmpdir/ssh" ]; then
        info "Restoring SSH..."
        mkdir -p "$HOME/.ssh"
        cp -rf "$tmpdir/ssh/"* "$HOME/.ssh/"
        chmod 700 "$HOME/.ssh"
        chmod 600 "$HOME/.ssh/id_"* 2>/dev/null || true
    fi

    # Restore Termux config
    if [ -d "$tmpdir/termux-config" ]; then
        info "Restoring Termux config..."
        mkdir -p "$HOME/.termux"
        cp -rf "$tmpdir/termux-config/"* "$HOME/.termux/"
    fi

    # Restore user bin
    if [ -d "$tmpdir/user-bin" ]; then
        info "Restoring ~/bin..."
        mkdir -p "$HOME/bin"
        cp -rf "$tmpdir/user-bin/"* "$HOME/bin/"
    fi

    # Reinstall packages
    if [ -f "$tmpdir/packages.txt" ]; then
        info "Reinstalling packages..."
        pkg update -y -q 2>/dev/null || true
        xargs pkg install -y < "$tmpdir/packages.txt" 2>/dev/null || true
    fi

    rm -rf "$tmpdir"
    ok "Restore complete! Restart Termux for all changes to take effect."
}

backup_list() {
    step "Available backups in $BACKUP_DIR:"
    if ls "$BACKUP_DIR"/*.tar.gz 1>/dev/null 2>&1; then
        for f in "$BACKUP_DIR"/*.tar.gz; do
            local size
            size=$(du -h "$f" | cut -f1)
            info "  $(basename "$f")  ($size)"
        done
    else
        info "  No backups found."
    fi
}

pkg_list() {
    dpkg --get-selections 2>/dev/null | awk '{print $1}'
}

pkg_restore() {
    local file="${1:-/dev/stdin}"
    step "Reinstalling packages..."
    pkg update -y -q 2>/dev/null || true
    xargs pkg install -y < "$file"
    ok "Package restore complete."
}

case "${1:-}" in
    save)        backup_save "${2:-}" ;;
    restore)     backup_restore "${2:-}" ;;
    list)        backup_list ;;
    pkg-list)    pkg_list ;;
    pkg-restore) pkg_restore "${2:-}" ;;
    --help|-h)   usage ;;
    "")          usage ;;
    *)           err "Unknown command: $1"; usage; exit 1 ;;
esac
