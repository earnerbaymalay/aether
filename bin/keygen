#!/data/data/com.termux/files/usr/bin/bash
# keygen — generate and manage SSH/GPG keys in Termux
set -euo pipefail
source "$(dirname "$0")/../lib/common.sh"

usage() {
    cat <<EOF
Usage: keygen <type> [options]

Generate and manage cryptographic keys.

Types:
  ssh [email]        Generate Ed25519 SSH key pair
  gpg [email]        Generate GPG key pair (RSA 4096)
  github             Generate SSH key and show instructions for GitHub
  age                Generate an age encryption key pair

Key management:
  list               List all SSH and GPG keys
  copy-pub           Copy SSH public key to clipboard (via termux-clipboard-set)
  show-pub           Print SSH public key to stdout

Options:
  --help, -h         Show this help

Examples:
  keygen ssh user@example.com
  keygen github
  keygen gpg "My Name <me@example.com>"
  keygen list
EOF
}

gen_ssh() {
    local email="${1:-termux@localhost}"
    local keyfile="$HOME/.ssh/id_ed25519"

    step "Generating Ed25519 SSH key..."
    mkdir -p "$HOME/.ssh"
    chmod 700 "$HOME/.ssh"

    if [ -f "$keyfile" ]; then
        warn "Key already exists at $keyfile"
        if ! confirm "Overwrite?"; then
            info "Keeping existing key."
            return
        fi
    fi

    ssh-keygen -t ed25519 -C "$email" -f "$keyfile" -N ""
    chmod 600 "$keyfile"
    chmod 644 "$keyfile.pub"

    ok "SSH key generated:"
    info "  Private: $keyfile"
    info "  Public:  $keyfile.pub"
    echo ""
    info "Your public key:"
    cat "$keyfile.pub"
}

gen_gpg() {
    local identity="${1:-Termux User <termux@localhost>}"

    step "Generating GPG key (RSA 4096)..."
    has gpg || pkg_install gnupg

    gpg --batch --gen-key <<GPGEOF
Key-Type: RSA
Key-Length: 4096
Subkey-Type: RSA
Subkey-Length: 4096
Name-Real: $(echo "$identity" | sed 's/ <.*//')
Name-Email: $(echo "$identity" | grep -oP '<\K[^>]+' || echo "termux@localhost")
Expire-Date: 2y
%no-protection
%commit
GPGEOF

    ok "GPG key generated. List with: gpg --list-keys"
}

gen_github() {
    gen_ssh "git@github.com"
    echo ""
    step "To add this key to GitHub:"
    info "1. Copy the public key above"
    info "2. Go to https://github.com/settings/ssh/new"
    info "3. Paste it and save"
    echo ""
    info "Or use 'keygen copy-pub' to copy to clipboard, then paste in browser."
    echo ""
    info "Test with: ssh -T git@github.com"
}

gen_age() {
    step "Generating age key pair..."
    has age || pkg_install age

    local keyfile="$HOME/.config/age/keys.txt"
    mkdir -p "$(dirname "$keyfile")"

    age-keygen -o "$keyfile" 2>&1
    chmod 600 "$keyfile"

    ok "age key saved to $keyfile"
}

list_keys() {
    step "SSH keys:"
    if [ -d "$HOME/.ssh" ]; then
        for pub in "$HOME/.ssh"/*.pub; do
            [ -f "$pub" ] && info "  $(basename "$pub"): $(cat "$pub")"
        done
    else
        info "  No SSH keys found."
    fi

    echo ""
    step "GPG keys:"
    if has gpg; then
        gpg --list-keys --keyid-format short 2>/dev/null || info "  No GPG keys found."
    else
        info "  gpg not installed."
    fi
}

copy_pub() {
    local pubkey="$HOME/.ssh/id_ed25519.pub"
    if [ ! -f "$pubkey" ]; then
        err "No public key found at $pubkey"
        exit 1
    fi

    if has termux-clipboard-set; then
        cat "$pubkey" | termux-clipboard-set
        ok "Public key copied to clipboard."
    else
        warn "termux-clipboard-set not found. Install termux-api package."
        info "Printing key instead:"
        cat "$pubkey"
    fi
}

show_pub() {
    local pubkey="$HOME/.ssh/id_ed25519.pub"
    if [ ! -f "$pubkey" ]; then
        err "No public key found at $pubkey"
        exit 1
    fi
    cat "$pubkey"
}

# --- Ensure openssh is installed ---
has ssh-keygen || pkg_install openssh

case "${1:-}" in
    ssh)        gen_ssh "${2:-}" ;;
    gpg)        gen_gpg "${2:-}" ;;
    github)     gen_github ;;
    age)        gen_age ;;
    list)       list_keys ;;
    copy-pub)   copy_pub ;;
    show-pub)   show_pub ;;
    --help|-h)  usage ;;
    "")         usage ;;
    *)          err "Unknown command: $1"; usage; exit 1 ;;
esac
